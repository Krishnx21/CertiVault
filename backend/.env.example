# ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────
# Local Docker Compose:
# MONGODB_URI=mongodb://root:rootpassword@localhost:27017/certivault?authSource=admin
# MongoDB Atlas:
MONGODB_URI=

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ISSUER=certivault-api
JWT_AUDIENCE=certivault-web
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────
# AWS S3
# ─────────────────────────────────────────
AWS_REGION=
S3_BUCKET_NAME=
# AWS credentials — use IAM role in production, not hard-coded keys
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────
# Upload limits
# ─────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760

# ─────────────────────────────────────────
# Logging
# ─────────────────────────────────────────
LOG_LEVEL=info
